{
    "name": "mogul360/social-dashboard-backend",
    "description": "Backend de Social Dashboard migrado a PHP 8.4",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "phpoffice/phpspreadsheet": "^2.3",
        "phpoffice/phpword": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}
