# ==============================================================================
# Configuración del Backend
# ==============================================================================
# Puerto donde corre el backend de FastAPI dentro del contenedor y se expone localmente
PORT=8000

# URL de la base de datos SQLite dentro del volumen del contenedor backend
DATABASE_URL=sqlite:////app/data/dashboard.db

# Contraseña requerida para autorizar la subida de planillas Excel en /api/upload
UPLOAD_PASSWORD=mogul360secret

# ==============================================================================
# Configuración del Frontend
# ==============================================================================
# La URL donde el frontend puede consultar la API del backend.
# - Dejar VACÍO u OMITIR (recomendado) para usar URLs relativas. Las solicitudes a la
#   API (/api/*) se redirigirán automáticamente a través del proxy inverso de Nginx
#   hacia el contenedor del backend. Es ideal para despliegues en un único dominio,
#   localhost, ngrok y arquitecturas estándar de contenedores.
# - Definir una URL absoluta (ej: http://localhost:8000 o http://api.tudominio.com)
#   únicamente si el frontend y el backend están alojados en servidores o dominios separados.
VITE_API_URL=

# ==============================================================================
# Configuración General
# ==============================================================================
# Modo de entorno (production, development)
NODE_ENV=production
